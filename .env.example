# ── Required ──────────────────────────────────────────────────────────
# Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Ethereum private key for SIWE auth (0x-prefixed)
PRIVATE_KEY=0x...

# ── Optional ──────────────────────────────────────────────────────────
# Target web3research instance (default: https://web3resear.ch)
BASE_URL=https://web3resear.ch

# Claude model to use (default: claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6

# Brave Search API key — improves search quality (free tier: 2000 req/mo)
# Get at: https://brave.com/search/api/
BRAVE_API_KEY=

# Temp working directory for screenshots & mermaid PNGs
WORK_DIR=/tmp/web3r-agent

# Max browser research iterations (default: 12)
MAX_RESEARCH_ITER=12

# Chain ID for SIWE (default: 1)
CHAIN_ID=1
